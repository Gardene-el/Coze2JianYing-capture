{
  "name": "coze2jianying-capture",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/_worker.js --format=esm --target=esnext",
    "build:server": "esbuild src/server.ts --bundle --outfile=dist/server.js --format=cjs --platform=node --target=node20 --external:better-sqlite3",
    "start:server": "node dist/server.js",
    "dev": "wrangler dev",
    "dev:server": "node --watch dist/server.js",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:create": "wrangler d1 create coze-capture",
    "db:init": "wrangler d1 execute coze-capture --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute coze-capture --remote --file=./schema.sql",
    "docker:build": "docker build -t coze2jianying-relay .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f relay"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "itty-router": "^5.0.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "wrangler": "^3.0.0"
  }
}
