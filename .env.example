# ============================================================
# Coze2JianYing Relay — standalone / Docker environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# HTTP port the server listens on (container-internal; mapped by docker-compose)
PORT=8787

# SQLite database file path inside the container
DB_PATH=/app/data/relay.db

# ------------------------------------------------------------------
# Authentication
# Set a strong random string to require  Authorization: Bearer <token>
# on every POST request.  Leave empty to disable authentication checks
# (not recommended for public deployments).
# ------------------------------------------------------------------
RELAY_SECRET=

# ------------------------------------------------------------------
# Data retention
# Records older than this many seconds are eligible for cleanup via
# POST /admin/cleanup.  Default: 604800 (7 days).
# ------------------------------------------------------------------
RECORD_TTL_SECONDS=604800

# ------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.
# The first entry is used as the fallback when the request has no
# Origin header or the origin is not in the list.
# ------------------------------------------------------------------
CORS_ORIGINS=https://coze.com,https://www.coze.com,https://coze.cn,https://www.coze.cn,http://localhost:3000
